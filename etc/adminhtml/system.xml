<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="magedrop" translate="label" sortOrder="400" class="magedrop-tab">
            <label>MageDrop</label>
        </tab>
        <section id="magedrop" translate="label" type="text" sortOrder="10" showInDefault="1">
            <label>Connection</label>
            <tab>magedrop</tab>
            <resource>MageDrop_Magento2::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1">
                <label>API Connection</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="api_token" translate="label comment" type="obscure" sortOrder="20" showInDefault="1">
                    <label>Module Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Copy this from your MageDrop dashboard under Store > Show Module Token</comment>
                </field>
            </group>
        </section>
    </system>
</config>
